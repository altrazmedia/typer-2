# Copy to .env and .env.local and fill in values.

# Host dev (`npm run local`, `npm run dev`): Postgres on localhost
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/typer_dev"

# Full Docker dev (`npm run local:docker`): DATABASE_URL is set in docker-compose.dev.yml
# (host `db`, not localhost). AUTH_SECRET is still read from .env / .env.local.

AUTH_SECRET="generate-a-long-random-string-for-production"
